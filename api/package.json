{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "CP Hub API — Fastify + Prisma + Redis + BullMQ",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
